PORT=3001
OPENAI_API_KEY=sk-...
KIS_APP_KEY=
KIS_APP_SECRET=
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
# Note: SUPABASE_JWT_SECRET was used for legacy HS256 verification; the server
# now verifies ES256 tokens via JWKS at SUPABASE_URL/auth/v1/.well-known/jwks.json
# and no longer reads SUPABASE_JWT_SECRET.
ALLOWED_ORIGINS=http://localhost:5173
DAILY_AI_LIMIT=20
